{
  "name": "curry-assistant",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:create": "wrangler d1 create curry-db",
    "db:migrate:local": "wrangler d1 migrations apply curry-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply curry-db --remote",
    "db:seed:local": "node scripts/generate-seed.js > /tmp/seed.sql && wrangler d1 execute curry-db --local --file=/tmp/seed.sql",
    "db:seed:remote": "node scripts/generate-seed.js > /tmp/seed.sql && wrangler d1 execute curry-db --remote --file=/tmp/seed.sql",
    "pages:dev": "wrangler pages dev dist --d1=DB=curry-db"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "exceljs": "^4.4.0",
    "hono": "^4.4.0",
    "jsonrepair": "^3.13.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.24.0",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "chardet": "^2.0.0",
    "iconv-lite": "^0.6.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
